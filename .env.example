# Supabase 프로젝트 설정
# Project URL: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Server-only secret key: Supabase Dashboard > Project Settings > API Keys
# 절대 NEXT_PUBLIC_ 접두사를 붙이거나 브라우저 코드에서 사용하지 마세요.
SUPABASE_SECRET_KEY=your_supabase_secret_key

# 외부 인증 GraphQL API (선택, 미설정 시 기본 실습 API 사용)
AUTH_GRAPHQL_URL=https://main-practice.codebootcamp.co.kr/graphql
